{
  "http": {
    "bind_addr": "127.0.0.1:39090"
  },
  "analytics": {
    "manifest_path": "examples/local-aux-storage-duckdb/manifest.json",
    "http": {
      "ingest_endpoint_enabled": false
    },
    "source": {
      "stream_type": "aux_storage",
      "endpoint_url": "http://127.0.0.1:39124/storage",
      "poll_interval_ms": 100,
      "poll_max_shards": 16,
      "poll_max_responses_per_interval": 160,
      "tables": [
        {
          "table_name": "analytics_canary"
        }
      ]
    },
    "catalog": {
      "backend": "duckdb",
      "connection_string": "examples/local-aux-storage-duckdb/run/analytics.duckdb"
    }
  },
  "features": {
    "metrics": {
      "enabled": true
    }
  }
}
